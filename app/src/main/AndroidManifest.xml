<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- A launcher must enumerate installed apps (see plan §2.2). -->
    <uses-permission
        android:name="android.permission.QUERY_ALL_PACKAGES" />
        

    <!-- Read connectivity/Wi-Fi state for the status indicator (both normal permissions). -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />

    <!-- Browse the device's photos for the optional image wallpaper (runtime-granted). -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE" />
        

    <!-- Read apps' home-screen preview channels/programs (the TV content carousel probe). Whether a
         non-system launcher is actually allowed to read other packages' rows is what we're testing. -->
    <uses-permission android:name="android.permission.READ_TV_LISTINGS" />

    <!-- App poster art (for artwork wallpapers) is often served from the web, so fetching it
         needs network access. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- TV app: no touchscreen; leanback optional so it still runs on phone/emulator. -->
    <uses-feature
        android:name="android.software.leanback"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.touchscreen"
        android:required="false" />

    <application
        android:name=".TarangApp"
        android:allowBackup="true"
        android:banner="@drawable/app_banner"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Tarang">

        <activity
            android:name=".home.HomeActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:screenOrientation="landscape"
            android:theme="@style/Theme.Tarang"
            tools:ignore="LockedOrientationActivity">

            <!-- Appears in the TV app drawer and can be launched normally. -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>

            <!-- HOME entry: lets the device set Tarang as the default launcher (plan §2.1, §8). -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- Fallback home redirect: when the stock launcher reaches the foreground, bounce back
             to Tarang. set-home-activity is the clean path but doesn't stick on Google TV
             (plan §2.1 / §9), so this service is the reliable mechanism. -->
        <service
            android:name=".home.HomeRedirectService"
            android:exported="true"
            android:label="@string/accessibility_service_label"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>
    </application>
</manifest>
